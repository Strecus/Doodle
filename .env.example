# Copy to `.env` and fill in. Never commit `.env`.

# OpenAPI / REST geocoder: GET request resolves 5-digit ZIP → US state (2 letters).
# URL must include `{zip}` where the ZIP is substituted, e.g.:
#   https://your-api.example.com/v1/geocode/zip/{zip}
VITE_GEOCODE_ZIP_URL=

# API key (exposed to the browser — use a key scoped to this endpoint only, or a dev proxy).
VITE_OPENAPI_API_KEY=

# How the key is sent: `bearer` → Authorization: Bearer <key>
#                     `x-api-key` → X-API-Key: <key>
VITE_OPENAPI_AUTH_STYLE=bearer
